    {
        "id": "ac56f888af4f8724",
        "type": "function",
        "z": "da813bbfd577c796",
        "name": "单个商品信息",
        "func": "const db = global.get('mysql');\nlet id = msg.req.query.id\nlet sql = \"SELECT *,a.id AS aid,a.name AS aname FROM product a, product_detail b WHERE a.id = b.product_id and a.id = ?\"\nawait db.sql(sql, id)\n    .then(res => {\n        let product;\n        for (let i = 0; i < res.length; i++) {\n            //判断是否和前一条记录是同一个商品    \n            if (i > 0) {\n                product.details.push({\n                    id: res[i].id,\n                    name: res[i].name,\n                    image: res[i].image,\n                    stock: res[i].stock,\n                    price: res[i].price,\n                    salePrice: res[i].sale_price,\n                })\n            } else {\n                product = {\n                    id: res[i].aid,\n                    name: res[i].aname,\n                    description: res[i].description,\n                    categoryId: res[i].category_id,\n                    showIndex: res[i].show_index,\n                    details: [{\n                        id: res[i].id,\n                        name: res[i].name,\n                        image: res[i].image,\n                        stock: res[i].stock,\n                        price: res[i].price,\n                        salePrice: res[i].sale_price,\n                    }]\n                }\n            }\n        }\n        msg.payload = product;\n    }).catch(err => {\n        console.log(err);\n        msg.payload = { code: 500, err }\n    })\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 320,
        "wires": [
            [
                "91957a35c6331fa0"
            ]
        ]
    },
