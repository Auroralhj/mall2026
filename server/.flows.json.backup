    {
        "id": "e5d9bf114207e486",
        "type": "function",
        "z": "da813bbfd577c796",
        "name": "按分类获取商品信息",
        "func": "const db = global.get('mysql');\nlet categoryId =  msg.req.query.categoryId\nlet sql = \"SELECT *,a.id AS aid,a.name AS aname FROM product a, product_detail b WHERE a.id = b.product_id\"\nif (categoryId) \n    sql = sql + \" and  a.category_id = \" + categoryId\nlet lastObj = null;\nawait db.sql(sql)\n    .then(res => {\n        let data = [] ;\n        for (let i=0;i<res.length;i++){\n            //判断是否和前一条记录是同一个商品    \n            if (lastObj && lastObj.id == res[i].aid ){\n                lastObj.details.push({\n                        id : res[i].id,\n                        name : res[i].name,\n                        image : res[i].image,\n                        stock : res[i].stock,\n                        price : res[i].price,\n                        salePrice : res[i].sale_price, \n                })\n            }else{\n                let obj = {\n                    id : res[i].aid,\n                    name : res[i].aname,\n                    description : res[i].description,\n                    categoryId : res[i].category_id,\n                    showIndex : res[i].show_index,\n                    details : [{\n                        id : res[i].id,\n                        name : res[i].name,\n                        image : res[i].image,\n                        stock : res[i].stock,\n                        price : res[i].price,\n                        salePrice : res[i].sale_price,\n                    }]\n                }\n                lastObj = obj;\n                data.push(obj);\n            }\n        }\n        msg.payload = data;\n    }).catch(err => {\n        console.log(err);\n        msg.payload = { code: 500, err };\n    })\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 220,
        "wires": [
            [
                "91957a35c6331fa0"
            ]
        ]
    },
