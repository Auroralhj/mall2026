    {
        "id": "8b8c35a5f7904961",
        "type": "function",
        "z": "a0c34c372201e04d",
        "name": "商品添加到购物车",
        "func": "const db = global.get('mysql');\nlet productId = msg.req.body.productId;     //商品id\nlet detailId = msg.req.body.detailId;       //具体商品id\nlet number = msg.req.body.quantity;         //商品数量\nlet userId = msg.req.session.user.id;       //当前登录用户id    \n// 这里应该要验证数据的合法性，比如用户id是否存在，储存是否足够等信息\n// 这里暂时不做验证\nawait db.sql(\"select * from cart where product_id = ? and detail_id = ? and user_id = ?\", productId, detailId, userId)\n    .then(async res => {\n        let now = new Date()\n        // 如果已经存在了这条记录，只要添加就数量就好了\n        if (res.length > 0) {\n            let cartId = res[0].id;\n            await db.sql(\"update cart set quantity = quantity + ?, update_time = ? where id = ? \", number, now, cartId)\n                .then(res => {\n                    msg.payload = { code: 200, message: \"更新成功！\" }\n                })\n                .catch(err => {\n                    console.log(err);\n                    msg.payload = { code: 500, err }\n                })\n        }\n        // 否则就是新增\n        else {\n            await db.sql(\"insert into cart(quantity, checked, product_id, detail_id, user_id, create_time, update_time) values(?, ?, ?, ?, ?, ?, ?)\",\n                number, true, productId, detailId, userId, now, now)\n                .then(res => {\n                    msg.payload = { code: 200, message: \"添加成功！\" }\n                })\n                .catch(err => {\n                    console.log(err);\n                    msg.payload = { code: 500, err }\n                })\n        }\n    })\n    .catch(err => {\n        console.log(err);\n        msg.payload = { code: 500, err }\n    })\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 930,
        "y": 240,
        "wires": [
            [
                "9d80a626647ff208"
            ]
        ]
    },
    {
        "id": "771bbd08430e5f93",
        "type": "function",
        "z": "a0c34c372201e04d",
        "name": "查询用户购物车中的商品",
        "func": "const db = global.get('mysql');\nlet userId = msg.req.session.user.id;\nawait db.sql(`SELECT *, a.id AS pid,b.id AS pdid,a.name AS pname\nFROM product a,product_detail b,cart c \nWHERE c.product_id = a.id AND c.detail_id = b.id AND c.user_id = ?`, userId)\n    .then(res => {\n        msg.payload = res;\n    })\n    .catch(err => {\n        console.log(err);\n        msg.payload = { code: 500, err }\n    })\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 950,
        "y": 320,
        "wires": [
            [
                "9d80a626647ff208"
            ]
        ]
    }
]